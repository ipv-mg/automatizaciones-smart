{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@pages": ["pages/index.ts"],
      "@data/*": ["data/*"],
      "@fixtures/*": ["fixtures/*"],
      "@services/*": ["services/*"]
    }
  }
}
